#!/usr/bin/env bash

set -e

if ! command -v claude &> /dev/null; then
    echo "Claude Code is not installed. Run runs/claude-code first."
    exit 1
fi

# Claude Code reads MCP servers from ~/.claude.json (user scope), not from
# settings.json — so register them through the CLI rather than the .ai build.

register_remote_mcp() {
    local transport="$1"
    local name="$2"
    local url="$3"
    local header="$4"

    if claude mcp get "$name" &> /dev/null; then
        echo "$name: already registered, skipping."
        return
    fi

    if [[ -n "$header" ]]; then
        claude mcp add --transport "$transport" -s user "$name" "$url" --header "$header"
    else
        claude mcp add --transport "$transport" -s user "$name" "$url"
    fi
    echo "$name: registered."
}

register_stdio_mcp() {
    local name="$1"
    shift
    local cmd=("$@")

    if claude mcp get "$name" &> /dev/null; then
        echo "$name: already registered, skipping."
        return
    fi

    claude mcp add -s user "$name" -- "${cmd[@]}"
    echo "$name: registered."
}

# GitHub Copilot MCP — prefer GITHUB_TOKEN env var, fall back to gh CLI
GITHUB_TOKEN="${GITHUB_TOKEN:-$(gh auth token 2>/dev/null)}"
if [[ -z "$GITHUB_TOKEN" ]]; then
    echo "No GitHub token found (set GITHUB_TOKEN or run 'gh auth login') — skipping githubcom."
else
    register_remote_mcp "http" "githubcom" \
        "https://api.githubcopilot.com/mcp/" \
        "Authorization: Bearer ${GITHUB_TOKEN}"
fi

register_stdio_mcp "context7" npx -y @upstash/context7-mcp
register_stdio_mcp "sequential-thinking" npx -y @modelcontextprotocol/server-sequential-thinking

# Personal overlay
register_remote_mcp "sse" "cloudflare" "https://mcp.cloudflare.com/mcp"
