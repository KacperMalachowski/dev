#!/usr/bin/env bash
# Wrapper for claude that auto-exits after writing to temp file
# Usage: claude-99-wrapper <temp_file> <prompt>

TEMP_FILE="$1"
shift
PROMPT="$@"

# Start claude in background, redirecting output to temp file
claude --dangerously-skip-permissions --model claude-sonnet-4-6 --print "$PROMPT" > "$TEMP_FILE" &
CLAUDE_PID=$!

# Monitor the temp file for writes
INITIAL_SIZE=$(stat -c%s "$TEMP_FILE" 2>/dev/null || echo "0")
TIMEOUT=60
ELAPSED=0

while [ $ELAPSED -lt $TIMEOUT ]; do
    sleep 0.5
    ELAPSED=$((ELAPSED + 1))

    # Check if file has been written to
    CURRENT_SIZE=$(stat -c%s "$TEMP_FILE" 2>/dev/null || echo "0")

    if [ "$CURRENT_SIZE" -gt "$INITIAL_SIZE" ] && [ "$CURRENT_SIZE" -gt 0 ]; then
        # File has been written, wait a bit more to ensure completion
        sleep 1
        # Kill the claude process
        kill $CLAUDE_PID 2>/dev/null
        exit 0
    fi

    # Check if process already exited
    if ! kill -0 $CLAUDE_PID 2>/dev/null; then
        wait $CLAUDE_PID
        exit $?
    fi
done

# Timeout - kill the process
kill $CLAUDE_PID 2>/dev/null
exit 1
