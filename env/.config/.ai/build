#!/usr/bin/env bash

set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [ -z "${XDG_CONFIG_HOME:-}" ]; then
    XDG_CONFIG_HOME="$HOME/.config"
fi

output_dir="$XDG_CONFIG_HOME/opencode"
output_file="$output_dir/opencode.json"

# Auto-detect profile
# Work overlay is a submodule pointing to internal GHES - inaccessible from personal devices
detect_profile() {
    if [ -f "$script_dir/overlays/work/opencode.json" ]; then
        echo "work"
    else
        echo "personal"
    fi
}

profile=$(detect_profile)
echo "Detected profile: $profile"

overlay_file="$script_dir/overlays/$profile/opencode.json"
base_file="$script_dir/base/opencode.json"

if [ ! -f "$base_file" ]; then
    echo "Error: base config not found at $base_file"
    exit 1
fi

if [ ! -f "$overlay_file" ]; then
    echo "Error: overlay config not found at $overlay_file"
    exit 1
fi

# Merge base + overlay using jq (deep merge, overlay takes precedence)
mkdir -p "$output_dir"
jq -s '.[0] * .[1]' "$base_file" "$overlay_file" > "$output_file"

echo "Built OpenCode config for profile '$profile' → $output_file"
